# Copy this to .env and fill in real values. .env is gitignored; this file is not.
# DO NOT put real keys here.

# ElevenLabs TTS — used by record-server.js /tts proxy
# Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Voice ID (default = Rachel). Browse voices at https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Model (eleven_turbo_v2_5 = fast + cheap, eleven_multilingual_v2 = higher quality)
ELEVENLABS_MODEL=eleven_turbo_v2_5
